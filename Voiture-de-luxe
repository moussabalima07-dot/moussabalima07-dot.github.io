.sspec{background:var(--card);padding:20px 16px;text-align:center;border:1px solid var(--line2);}
.sspec-val{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;color:var(--gold2);}
.sspec-unit{font-size:0.7rem;color:var(--gold);}
.sspec-label{font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:6px;}
.spotlight-price-row{display:flex;align-items:center;gap:40px;margin-bottom:32px;padding-top:28px;border-top:1px solid var(--line2);}
.spotlight-price-label{font-size:0.58rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
.spotlight-price-val{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:700;color:var(--gold2);}
.spotlight-price-currency{font-size:1.4rem;color:var(--muted);}
.spotlight-actions{display:flex;gap:14px;}
.academie{padding:120px 60px;background:var(--black);}
.academie-header{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:80px;}
.academie-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;}
.academie-card{background:var(--card);border:1px solid var(--line2);overflow:hidden;transition:transform 0.4s;}
.academie-card:hover{transform:translateY(-6px);}
.academie-card:hover .academie-img img{transform:scale(1.04);}
.academie-img{height:220px;overflow:hidden;position:relative;}
.academie-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.5s;}
.academie-img::after{content:'';position:absolute;bottom:0;left:0;right:0;height:50%;background:linear-gradient(transparent,var(--card));z-index:1;}
.academie-cat{position:absolute;top:16px;left:16px;z-index:2;background:var(--gold);color:var(--black);padding:4px 12px;font-size:0.5rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;}
.academie-body{padding:28px;}
.academie-date{font-size:0.58rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;}
.academie-title{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:600;line-height:1.3;margin-bottom:12px;}
.academie-desc{font-size:0.72rem;line-height:1.8;color:var(--muted);font-weight:300;margin-bottom:20px;}
.academie-footer{display:flex;align-items:center;justify-content:space-between;padding-top:16px;border-top:1px solid var(--line2);}
.academie-author{font-size:0.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted2);}
.academie-link{font-size:0.6rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gold);}
.evenements{padding:120px 60px;background:var(--dark2);}
.evenements-header{text-align:center;margin-bottom:80px;}
.evenements-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;}
.event-card{background:var(--card);border:1px solid var(--line2);display:grid;grid-template-columns:140px 1fr;overflow:hidden;transition:all 0.3s;}
.event-card:hover{border-color:var(--line);transform:translateX(4px);}
.event-date-box{background:var(--dark2);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px 16px;border-right:1px solid var(--line2);}
.event-day{font-family:'Cormorant Garamond',serif;font-size:3.2rem;font-weight:700;color:var(--gold2);line-height:1;}
.event-month{font-size:0.58rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-top:4px;}
.event-year{font-size:0.52rem;letter-spacing:2px;color:var(--muted2);margin-top:2px;}
.event-body{padding:24px 28px;}
.event-type{font-size:0.55rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;}
.event-title{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:600;line-height:1.2;margin-bottom:8px;}
.event-desc{font-size:0.7rem;line-height:1.8;color:var(--muted);font-weight:300;margin-bottom:14px;}
.event-meta{display:flex;gap:20px;flex-wrap:wrap;}
.event-meta-item{font-size:0.56rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted2);}
.event-register{display:inline-flex;align-items:center;gap:8px;font-size:0.56rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gold);border:1px solid var(--gold);padding:7px 14px;margin-top:14px;transition:all 0.3s;}
.event-register:hover{background:var(--gold);color:var(--black);}
.event-card.featured-event{grid-column:span 2;grid-template-columns:160px 1fr;}
.event-card.featured-event .event-date-box{background:var(--gold);}
.event-card.featured-event .event-day{color:var(--black);}
.event-card.featured-event .event-month{color:rgba(0,0,0,0.6);}
.services-section{padding:120px 60px;background:var(--black);}
.services-header{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:80px;}
.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;}
.service-card{background:var(--card);padding:40px 32px;border:1px solid var(--line2);position:relative;overflow:hidden;transition:all 0.4s;}
.service-card::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transition:transform 0.4s;}
.service-card:hover{background:var(--card2);}
.service-card:hover::before{transform:scaleX(1);}
.service-num{font-family:'Cormorant Garamond',serif;font-size:4rem;font-weight:700;color:rgba(201,168,76,0.06);position:absolute;top:10px;right:20px;user-select:none;}
.service-icon{font-size:1.8rem;margin-bottom:24px;color:var(--muted2);}
.service-name{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:600;margin-bottom:14px;}
.service-desc{font-size:0.75rem;line-height:1.8;color:var(--muted);font-weight:300;}
.testimonials{padding:120px 60px;background:var(--dark2);position:relative;overflow:hidden;}
.testi-bg-text{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Cormorant Garamond',serif;font-size:20rem;font-weight:700;color:rgba(201,168,76,0.02);white-space:nowrap;pointer-events:none;user-select:none;}
.testi-header{text-align:center;margin-bottom:80px;position:relative;z-index:1;}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;position:relative;z-index:1;}
.testi-card{background:var(--card);padding:40px 36px;border:1px solid var(--line2);position:relative;overflow:hidden;}
.testi-card::before{content:'"';font-family:'Cormorant Garamond',serif;font-size:8rem;font-weight:700;color:rgba(201,168,76,0.08);position:absolute;top:-10px;left:20px;line-height:1;}
.testi-stars{display:flex;gap:4px;margin-bottom:20px;position:relative;z-index:1;}
.star{color:var(--gold);font-size:0.8rem;}
.testi-text{font-size:0.82rem;line-height:1.9;color:var(--muted);font-weight:300;margin-bottom:28px;font-style:italic;position:relative;z-index:1;}
.testi-author{display:flex;align-items:center;gap:16px;position:relative;z-index:1;}
.testi-avatar{width:48px;height:48px;border-radius:50%;background:var(--card2);border:2px solid var(--gold);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:700;color:var(--gold2);flex-shrink:0;}
.testi-name{font-size:0.78rem;font-weight:700;color:var(--white);}
.testi-role{font-size:0.62rem;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-top:2px;}
.testi-car{font-size:0.58rem;color:var(--muted);margin-top:2px;}
.cta-section{padding:120px 60px;background:var(--gold);position:relative;overflow:hidden;text-align:center;}
.cta-section::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,transparent,rgba(0,0,0,0.08));}
.cta-section::after{content:'VELOCE';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Cormorant Garamond',serif;font-size:22rem;font-weight:700;color:rgba(0,0,0,0.04);white-space:nowrap;pointer-events:none;}
.cta-content{position:relative;z-index:1;}
.cta-label{font-size:0.62rem;font-weight:700;letter-spacing:5px;text-transform:uppercase;color:rgba(0,0,0,0.5);margin-bottom:20px;}
.cta-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2.4rem,5vw,4.5rem);font-weight:700;color:var(--black);line-height:1.1;margin-bottom:16px;}
.cta-sub{font-size:0.8rem;color:rgba(0,0,0,0.55);font-weight:300;margin-bottom:48px;line-height:1.7;}
.cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}
.btn-dark{background:var(--black);color:var(--gold);padding:16px 40px;font-size:0.68rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;border:none;transition:all 0.3s;}
.btn-dark:hover{background:var(--dark2);transform:translateY(-2px);}
.btn-outline-dark{background:transparent;color:var(--black);padding:15px 36px;font-size:0.68rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;border:2px solid var(--black);transition:all 0.3s;}
.btn-outline-dark:hover{background:var(--black);color:var(--gold);}
footer{background:var(--dark);border-top:1px solid var(--line2);padding:80px 60px 40px;}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:60px;margin-bottom:60px;}
.footer-logo{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:700;letter-spacing:6px;color:var(--white);margin-bottom:20px;}
.footer-logo span{color:var(--gold);}
.footer-tagline{font-size:0.72rem;line-height:1.9;color:var(--muted);font-weight:300;max-width:300px;margin-bottom:28px;}
.footer-social{display:flex;gap:12px;}
.social-btn{width:38px;height:38px;border:1px solid var(--line2);background:transparent;color:var(--muted);display:flex;align-items:center;justify-content:center;font-size:0.7rem;transition:all 0.3s;}
.social-btn:hover{border-color:var(--gold);color:var(--gold);}
.footer-col-title{font-size:0.6rem;font-weight:800;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:24px;}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:12px;}
.footer-links a{font-size:0.76rem;color:var(--muted);font-weight:300;transition:color 0.3s;display:flex;align-items:center;gap:8px;}
.footer-links a::before{content:'—';font-size:0.5rem;color:var(--gold);opacity:0;transition:opacity 0.3s;}
.footer-links a:hover{color:var(--white);}
.footer-links a:hover::before{opacity:1;}
.footer-bottom{padding-top:40px;border-top:1px solid var(--line2);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;}
.footer-copy{font-size:0.62rem;color:var(--muted2);letter-spacing:2px;text-transform:uppercase;}
.footer-legal{display:flex;gap:24px;}
.footer-legal a{font-size:0.6rem;color:var(--muted2);transition:color 0.3s;}
.footer-legal a:hover{color:var(--gold);}
.modal{position:fixed;inset:0;z-index:5000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;visibility:hidden;transition:all 0.4s;}
.modal.open{opacity:1;visibility:visible;}
.modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,0.85);backdrop-filter:blur(8px);}
.modal-box{position:relative;z-index:1;background:var(--card);border:1px solid var(--line);max-width:600px;width:100%;padding:50px;transform:translateY(30px);transition:transform 0.4s;}
.modal.open .modal-box{transform:translateY(0);}
.modal-close{position:absolute;top:20px;right:20px;background:transparent;border:none;color:var(--muted);font-size:1.2rem;transition:color 0.2s;}
.modal-close:hover{color:var(--gold);}
.modal-tag{font-size:0.6rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:16px;}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-weight:600;margin-bottom:8px;}
.modal-subtitle{font-size:0.75rem;color:var(--muted);margin-bottom:32px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.form-group{margin-bottom:16px;}
.form-group label{display:block;font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
.form-group input,.form-group select,.form-group textarea{width:100%;background:var(--dark2);border:1px solid var(--line2);color:var(--white);padding:12px 16px;font-size:0.8rem;font-family:'Montserrat';outline:none;transition:border-color 0.3s;}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--gold);}
.form-group textarea{resize:none;height:80px;}
.reveal{opacity:0;transform:translateY(40px);transition:opacity 0.8s,transform 0.8s;}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-delay-1{transition-delay:0.1s;}
.reveal-delay-2{transition-delay:0.2s;}
.reveal-delay-3{transition-delay:0.3s;}
.loader{position:fixed;inset:0;z-index:10000;background:var(--black);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:32px;transition:opacity 0.8s,visibility 0.8s;}
.loader.hidden{opacity:0;visibility:hidden;}
.loader-logo{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:700;letter-spacing:10px;color:var(--white);animation:logoPulse 1.5s ease-in-out infinite;}
.loader-logo span{color:var(--gold);}
.loader-bar{width:200px;height:1px;background:var(--muted2);position:relative;overflow:hidden;}
.loader-bar::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:var(--gold);animation:loaderBar 2s ease forwards;}
.loader-text{font-size:0.58rem;letter-spacing:5px;text-transform:uppercase;color:var(--muted);}
@keyframes logoPulse{0%,100%{opacity:1;}50%{opacity:0.5;}}
@keyframes loaderBar{0%{left:-100%;}100%{left:0%;}}
@media(max-width:1100px){.cars-grid{grid-template-columns:repeat(2,1fr);}.car-card.featured{grid-column:span 2;}.spotlight-inner,.academie-header,.services-header{grid-template-columns:1fr;gap:40px;}.services-grid{grid-template-columns:repeat(2,1fr);}.testi-grid,.academie-grid{grid-template-columns:repeat(2,1fr);}.footer-top{grid-template-columns:1fr 1fr;}.config-layout{grid-template-columns:1fr;height:auto;overflow-y:auto;}.config-preview{height:50vh;}.evenements-grid{grid-template-columns:1fr;}.event-card.featured-event{grid-column:span 1;grid-template-columns:120px 1fr;}.detail-body{grid-template-columns:1fr;}}
@media(max-width:768px){nav{padding:0 24px;}.nav-links{display:none;}.section,.spotlight,.services-section,.testimonials,.cta-section,.academie,.evenements{padding:80px 24px;}.filter-section{padding:0 24px 40px;}.cars-grid{padding:0 24px;grid-template-columns:1fr;}.car-card.featured{grid-column:span 1;}.hero-content{padding:0 24px;}.hero-stats{left:24px;right:24px;gap:30px;}.spotlight-specs{grid-template-columns:repeat(2,1fr);}.testi-grid,.services-grid,.academie-grid{grid-template-columns:1fr;}.footer-top{grid-template-columns:1fr;}footer{padding:60px 24px 30px;}.brands-section{padding:60px 24px;}.hero-car{display:none;}.hero-title{font-size:3rem;}.detail-hero-info{bottom:30px;left:24px;right:24px;}.detail-body{padding:40px 24px;}.detail-specs-grid{grid-template-columns:repeat(2,1fr);}.detail-gallery{grid-template-columns:1fr;}.event-card{grid-template-columns:100px 1fr;}}

</style>
</head>
