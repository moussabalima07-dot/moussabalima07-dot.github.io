    ctx.clearRect(0,0,W,H);
    pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0)p.x=W;if(p.x>W)p.x=0;if(p.y<0)p.y=H;if(p.y>H)p.y=0;ctx.beginPath();ctx.arc(p.x,p.y,p.s,0,Math.PI*2);ctx.fillStyle=`rgba(201,168,76,${p.o})`;ctx.fill();});
    for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<120){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.strokeStyle=`rgba(201,168,76,${.06*(1-d/120)})`;ctx.lineWidth=.5;ctx.stroke();}}
    requestAnimationFrame(draw);
  })();
})();

// REVEAL
const ro=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible');}),{threshold:.1,rootMargin:'0px 0px -60px 0px'});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

// FILTER/SORT
function filterCars(cat,btn){document.querySelectorAll('.filter-tab').forEach(b=>b.classList.remove('active'));btn.classList.add('active');document.querySelectorAll('.car-card').forEach(c=>{const s=cat==='all'||c.dataset.cat===cat;c.style.opacity=s?'1':'.2';c.style.transform=s?'':'scale(.96)';});}
function sortCars(v){const g=document.getElementById('carsGrid');[...g.querySelectorAll('.car-card')].sort((a,b)=>{const pa=+a.dataset.price,pb=+b.dataset.price;return v==='price-asc'?pa-pb:pb-pa;}).forEach(c=>g.appendChild(c));}

// FAV
function toggleFav(btn,e){e.stopPropagation();btn.classList.toggle('active');btn.textContent=btn.classList.contains('active')?'♥':'♡';}

// LIGHTBOX
let lbImgs=[],lbIdx=0;
function openLightboxSingle(src,cap){document.getElementById('lightbox-img').src=src;document.getElementById('lightbox-caption').textContent=cap;document.getElementById('lightbox').classList.add('open');document.body.style.overflow='hidden';}
function closeLightbox(){document.getElementById('lightbox').classList.remove('open');document.body.style.overflow='';}
function lightboxNav(d){if(!lbImgs.length)return;lbIdx=(lbIdx+d+lbImgs.length)%lbImgs.length;document.getElementById('lightbox-img').src=lbImgs[lbIdx].src;document.getElementById('lightbox-caption').textContent=lbImgs[lbIdx].cap;}
document.getElementById('lightbox').addEventListener('click',function(e){if(e.target===this)closeLightbox();});

// DETAIL
function openDetail(id){
  const c=CARS[id];if(!c)return;
  const specsH=c.specs.map(s=>`<div class="dspec"><div class="dspec-val">${s.v}<span class="dspec-unit">${s.u||''}</span></div><div class="dspec-label">${s.l}</div></div>`).join('');
  const featH=c.features.map(f=>`<div class="detail-feature">${f}</div>`).join('');
  const otherIds=Object.keys(CARS).filter(k=>k!==id).slice(0,4);
  const galH=otherIds.map(oid=>`<div class="detail-gallery-img" onclick="openLightboxSingle('${CARS[oid].img}','${CARS[oid].brand} ${CARS[oid].name}')"><img src="${CARS[oid].img}" alt="${CARS[oid].name}"></div>`).join('');
  document.getElementById('detailContent').innerHTML=`
    <div class="detail-hero"><img src="${c.img}" alt="${c.name}"><div class="detail-hero-overlay"></div>
      <div class="detail-hero-info"><div class="detail-brand">${c.brand}</div><h1 class="detail-title"><strong>${c.name}</strong></h1><div class="detail-subtitle">${c.version}</div></div>
    </div>
    <div class="detail-body">
      <div>
        <div class="detail-tabs">
          <div class="detail-tab active" onclick="switchTab(this,'t1')">Vue d'ensemble</div>
          <div class="detail-tab" onclick="switchTab(this,'t2')">Spécifications</div>
          <div class="detail-tab" onclick="switchTab(this,'t3')">Galerie</div>
        </div>
        <div class="detail-tab-content active" id="t1">
          <p class="detail-desc">${c.desc}</p>
          <div class="detail-specs-grid">${specsH}</div>
          <div style="font-size:.6rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:16px">Équipements Notables</div>
          <div class="detail-features">${featH}</div>
        </div>
        <div class="detail-tab-content" id="t2">
          <div class="detail-specs-grid" style="margin-bottom:40px">${specsH}</div>
          <table style="width:100%;border-collapse:collapse">${c.features.map(f=>`<tr style="border-bottom:1px solid var(--line2)"><td style="padding:14px 0;font-size:.72rem;color:var(--muted)">${f}</td><td style="padding:14px 0;font-size:.72rem;color:var(--gold);text-align:right">✓ Inclus</td></tr>`).join('')}</table>
        </div>
        <div class="detail-tab-content" id="t3">
          <div class="detail-gallery">
            <div class="detail-gallery-img" style="grid-column:span 2" onclick="openLightboxSingle('${c.img}','${c.brand} ${c.name}')"><img src="${c.img}" alt="${c.name}" style="height:300px"></div>
            ${galH}
          </div>
          <p style="font-size:.62rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:12px">Cliquez pour agrandir</p>
        </div>
      </div>
      <div>
        <div class="detail-price-box">
          <div class="detail-price-label">Prix de vente</div>
          <div class="detail-price"><span style="font-size:1.3rem;color:var(--muted)">€ </span>${c.price}</div>
          <div class="detail-stock"><div class="detail-stock-dot"></div>En stock — Disponible immédiatement</div>
          <div class="detail-sidebar-actions">
            <button class="btn-primary" onclick="openModal()">Réserver un Essai</button>
            <button class="config-btn-sm" onclick="openConfig('${id}')">⚙ Configurer ce Véhicule</button>
            <button class="btn-ghost" style="text-align:center;padding:12px" onclick="openModal()">Demander une Offre</button>
          </div>
        </div>
        <div style="background:var(--card);border:1px solid var(--line2);padding:24px;margin-top:2px">
          <div style="font-size:.58rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:12px">Financement Estimé</div>
          <div style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;color:var(--white)">${Math.round(c.basePrice/60).toLocaleString('fr-FR')} €<span style="font-size:.8rem;color:var(--muted);font-family:'Montserrat'">/mois</span></div>
          <div style="font-size:.6rem;color:var(--muted2);margin-top:6px">Sur 60 mois · 20% apport · Sous réserve</div>
        </div>
      </div>
    </div>`;
  document.getElementById('detailPage').classList.add('open');
  document.getElementById('detailPage').scrollTop=0;
  document.body.style.overflow='hidden';
}
function closeDetail(){document.getElementById('detailPage').classList.remove('open');document.body.style.overflow='';}
function switchTab(btn,id){document.querySelectorAll('.detail-tab').forEach(t=>t.classList.remove('active'));document.querySelectorAll('.detail-tab-content').forEach(t=>t.classList.remove('active'));btn.classList.add('active');document.getElementById(id).classList.add('active');}

// CONFIG
let cfgBase=0,cfgExtras={wheel:0,int:0,opts:0};
function openConfig(id){
  const c=CARS[id]||CARS.lambo;cfgBase=c.basePrice;cfgExtras={wheel:0,int:0,opts:0};
  document.getElementById('configCarImg').src=c.img;
  document.getElementById('configBrand').textContent=c.brand;
  document.getElementById('configTitle').innerHTML='<strong>'+c.name+'</strong>';
  document.getElementById('colorOverlay').style.background='#1a1a2a';
  document.querySelectorAll('.config-color').forEach((el,i)=>el.classList.toggle('active',i===0));
  document.getElementById('selectedColorName').textContent='Noir Profond';
  document.querySelectorAll('.config-wheel').forEach((el,i)=>el.classList.toggle('active',i===0));
  document.querySelectorAll('.config-int-item').forEach((el,i)=>el.classList.toggle('active',i===0));
  document.querySelectorAll('.config-option').forEach(el=>el.classList.remove('active'));
  updateCfgPrice();
  document.getElementById('configPage').classList.add('open');
  document.body.style.overflow='hidden';
  initCfgCanvas();
}
function closeConfig(){document.getElementById('configPage').classList.remove('open');document.body.style.overflow='';}
function selectColor(el){document.querySelectorAll('.config-color').forEach(c=>c.classList.remove('active'));el.classList.add('active');document.getElementById('colorOverlay').style.background=el.dataset.color;document.getElementById('selectedColorName').textContent=el.dataset.name;}
function selectWheel(el,price){document.querySelectorAll('.config-wheel').forEach(c=>c.classList.remove('active'));el.classList.add('active');cfgExtras.wheel=price;updateCfgPrice();}
function selectInterior(el,price){document.querySelectorAll('.config-int-item').forEach(c=>c.classList.remove('active'));el.classList.add('active');cfgExtras.int=price;updateCfgPrice();}
function toggleOption(el,price){el.classList.toggle('active');let t=0;document.querySelectorAll('.config-option.active').forEach(o=>{const m=o.getAttribute('onclick').match(/\d+/);if(m)t+=+m[0];});cfgExtras.opts=t;updateCfgPrice();}
function updateCfgPrice(){const t=cfgBase+cfgExtras.wheel+cfgExtras.int+cfgExtras.opts;document.getElementById('configTotalPrice').textContent='€ '+t.toLocaleString('fr-FR');}
function resetConfig(){document.querySelectorAll('.config-color').forEach((el,i)=>el.classList.toggle('active',i===0));document.getElementById('colorOverlay').style.background='#1a1a2a';document.getElementById('selectedColorName').textContent='Noir Profond';document.querySelectorAll('.config-wheel').forEach((el,i)=>el.classList.toggle('active',i===0));document.querySelectorAll('.config-int-item').forEach((el,i)=>el.classList.toggle('active',i===0));document.querySelectorAll('.config-option').forEach(el=>el.classList.remove('active'));cfgExtras={wheel:0,int:0,opts:0};updateCfgPrice();}
function initCfgCanvas(){const c=document.getElementById('configCanvas');if(!c)return;const ctx=c.getContext('2d');let W=c.width=c.offsetWidth,H=c.height=c.offsetHeight,pts=[];for(let i=0;i<40;i++)pts.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3});(function d(){if(!document.getElementById('configPage').classList.contains('open'))return;ctx.clearRect(0,0,W,H);pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;ctx.beginPath();ctx.arc(p.x,p.y,1,0,Math.PI*2);ctx.fillStyle='rgba(201,168,76,.15)';ctx.fill();});requestAnimationFrame(d);})();}

// MODAL
function openModal(){document.getElementById('modal').classList.add('open');document.body.style.overflow='hidden';}
function closeModal(){document.getElementById('modal').classList.remove('open');document.body.style.overflow='';}
function submitForm(){const btn=event.target;btn.textContent='✓ Demande Envoyée — Nous vous contactons sous 2h';btn.style.background='#25d366';btn.style.color='white';setTimeout(closeModal,2500);setTimeout(()=>{btn.textContent='Envoyer la Demande';btn.style.background='';btn.style.color='';},3000);}
document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeModal();closeDetail();closeConfig();closeLightbox();}});

// PARALLAX
document.addEventListener('mousemove',e=>{const car=document.querySelector('.hero-car');if(!car)return;car.style.transform=`translateY(-50%) translateX(${(e.clientX/innerWidth-.5)*3}px) translateY(${(e.clientY/innerHeight-.5)*2}px)`;});

// COUNTER
function animC(el,target,suf=''){let c=0;const t=setInterval(()=>{c+=target/60;if(c>=target){el.textContent=target+suf;clearInterval(t);}else el.textContent=Math.floor(c)+suf;},20);}
new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.querySelectorAll('.hero-stat-num').forEach(n=>{const txt=n.textContent;animC(n,parseInt(txt),txt.replace(/[0-9]/g,''));});}),{threshold:.5}).observe(document.querySelector('.hero-stats'));
</script>
</body>
