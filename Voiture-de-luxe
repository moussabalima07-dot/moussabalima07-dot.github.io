          <div class="config-wheel" onclick="selectWheel(this,18000)"><div class="config-wheel-icon">🏆</div><div class="config-wheel-name">Carbone 22"</div><div style="font-family:'Cormorant Garamond',serif;font-size:0.9rem;color:var(--gold);margin-top:4px">+ €18 000</div></div>
