(function(){
  const c=document.getElementById('heroCanvas');if(!c)return;
  const ctx=c.getContext('2d');let W,H,pts=[];
  function resize(){W=c.width=innerWidth;H=c.height=innerHeight;}
  resize();window.addEventListener('resize',resize);
  for(let i=0;i<80;i++)pts.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.4,vy:(Math.random()-.5)*.2,s:Math.random()*1.5+.3,o:Math.random()*.4+.1});
