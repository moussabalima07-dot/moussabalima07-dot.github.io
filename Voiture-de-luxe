.spotlight-subtitle{font-size:0.7rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:28px;}
.spotlight-desc{font-size:0.8rem;line-height:1.9;color:var(--muted);margin-bottom:40px;font-weight:300;}
