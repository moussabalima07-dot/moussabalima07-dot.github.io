<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>VELOCE — Automobiles d'Exception</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Montserrat:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{--black:#050507;--dark:#0a0a0f;--dark2:#111118;--card:#13131c;--card2:#1a1a26;--gold:#c9a84c;--gold2:#e8c97a;--white:#f5f0e8;--muted:#7a7a8a;--muted2:#4a4a5a;--red:#c0392b;--line:rgba(201,168,76,0.15);--line2:rgba(255,255,255,0.06);}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Montserrat',sans-serif;background:var(--black);color:var(--white);overflow-x:hidden;}
a{text-decoration:none;color:inherit;}
img{display:block;max-width:100%;}
button{font-family:'Montserrat',sans-serif;}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-track{background:var(--dark);}
::-webkit-scrollbar-thumb{background:var(--gold);border-radius:2px;}



nav{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:0 60px;display:flex;align-items:center;justify-content:space-between;height:80px;transition:all 0.4s;}
nav.scrolled{background:rgba(5,5,7,0.95);backdrop-filter:blur(20px);border-bottom:1px solid var(--line);height:64px;}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.9rem;font-weight:700;letter-spacing:6px;color:var(--white);display:flex;align-items:center;gap:12px;}
.nav-logo span{color:var(--gold);}
.nav-logo::before{content:'';display:block;width:28px;height:2px;background:var(--gold);}
.nav-links{display:flex;align-items:center;gap:40px;list-style:none;}
.nav-links a{font-size:0.68rem;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--muted);transition:color 0.3s;position:relative;padding-bottom:4px;}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--gold);transition:width 0.3s;}
.nav-links a:hover{color:var(--white);}
.nav-links a:hover::after{width:100%;}
.nav-cta{background:transparent;border:1px solid var(--gold);color:var(--gold);padding:10px 24px;font-size:0.65rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;transition:all 0.3s;}
.nav-cta:hover{background:var(--gold);color:var(--black);}
.hero{position:relative;height:100vh;min-height:700px;display:flex;align-items:center;overflow:hidden;}
.hero-canvas{position:absolute;inset:0;z-index:0;}
.hero-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(90deg,rgba(5,5,7,0.85) 0%,rgba(5,5,7,0.4) 55%,transparent 100%);}
.hero-car{position:absolute;right:3%;top:50%;transform:translateY(-50%);width:58%;z-index:2;animation:carFloat 6s ease-in-out infinite;}
@keyframes carFloat{0%,100%{transform:translateY(-50%);}50%{transform:translateY(-52%) translateX(-8px);}}
.hero-car img{width:100%;filter:drop-shadow(0 40px 80px rgba(201,168,76,0.2));object-fit:contain;}
.hero-content{position:relative;z-index:3;padding:0 60px;max-width:580px;}
.hero-tag{display:inline-flex;align-items:center;gap:10px;font-size:0.62rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:28px;}
.hero-tag::before{content:'';width:30px;height:1px;background:var(--gold);}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(3.2rem,6vw,5.5rem);font-weight:300;line-height:1.0;letter-spacing:2px;margin-bottom:8px;}
.hero-title strong{font-weight:700;color:var(--gold);font-style:italic;display:block;}
.hero-sub{font-size:0.78rem;font-weight:300;letter-spacing:2px;color:var(--muted);margin-bottom:40px;line-height:1.8;text-transform:uppercase;}
.hero-actions{display:flex;gap:16px;flex-wrap:wrap;}
.btn-primary{background:var(--gold);color:var(--black);padding:16px 36px;font-size:0.68rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;border:none;transition:all 0.3s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
.btn-primary:hover{background:var(--gold2);transform:translateY(-2px);box-shadow:0 20px 40px rgba(201,168,76,0.3);}
.btn-ghost{background:transparent;color:var(--white);padding:15px 32px;font-size:0.68rem;font-weight:600;letter-spacing:3px;text-transform:uppercase;border:1px solid var(--line2);transition:all 0.3s;}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold);}
.hero-stats{position:absolute;bottom:50px;left:60px;right:60px;z-index:3;display:flex;gap:60px;}
.hero-stat-num{font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:700;color:var(--gold2);line-height:1;}
.hero-stat-num sup{font-size:1rem;}
.hero-stat-label{font-size:0.6rem;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-top:6px;}
.hero-scroll{position:absolute;right:40px;top:50%;transform:translateY(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:12px;writing-mode:vertical-rl;font-size:0.58rem;letter-spacing:3px;color:var(--muted);text-transform:uppercase;}
.hero-scroll::after{content:'';display:block;width:1px;height:60px;background:linear-gradient(var(--gold),transparent);animation:scrollLine 2s ease-in-out infinite;}
@keyframes scrollLine{0%{transform:scaleY(0);transform-origin:top;}50%{transform:scaleY(1);transform-origin:top;}51%{transform:scaleY(1);transform-origin:bottom;}100%{transform:scaleY(0);transform-origin:bottom;}}
.marquee-wrap{background:var(--gold);padding:14px 0;overflow:hidden;}
.marquee-track{display:flex;white-space:nowrap;animation:marquee 25s linear infinite;}
.marquee-item{display:inline-flex;align-items:center;gap:24px;padding:0 40px;font-size:0.62rem;font-weight:800;letter-spacing:4px;text-transform:uppercase;color:var(--black);}
.marquee-dot{width:4px;height:4px;background:var(--black);border-radius:50%;}
@keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}
.section{padding:120px 60px;}
.section-label{display:inline-flex;align-items:center;gap:12px;font-size:0.6rem;font-weight:700;letter-spacing:5px;text-transform:uppercase;color:var(--gold);margin-bottom:18px;}
.section-label::before{content:'';width:24px;height:1px;background:var(--gold);}
.section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2.4rem,4vw,3.8rem);font-weight:300;line-height:1.1;}
.section-title em{font-style:italic;color:var(--gold);}
.section-divider{width:60px;height:1px;background:var(--gold);margin:28px 0;}
.section-desc{font-size:0.82rem;font-weight:300;line-height:1.9;color:var(--muted);max-width:500px;}
.brands-section{padding:80px 60px;border-top:1px solid var(--line2);border-bottom:1px solid var(--line2);}
.brands-title{font-size:0.6rem;letter-spacing:5px;text-transform:uppercase;color:var(--muted);text-align:center;margin-bottom:50px;}
.brands-grid{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:60px 80px;}
.brand-item{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--muted2);transition:color 0.3s;user-select:none;}
.brand-item:hover{color:var(--gold);}
.filter-section{padding:0 60px 60px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px;}
.filter-tabs{display:flex;gap:4px;flex-wrap:wrap;}
.filter-tab{background:transparent;border:1px solid var(--line2);color:var(--muted);padding:10px 22px;font-size:0.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;transition:all 0.25s;}
.filter-tab:hover,.filter-tab.active{background:var(--gold);border-color:var(--gold);color:var(--black);}
.filter-sort{display:flex;align-items:center;gap:16px;}
.filter-sort label{font-size:0.6rem;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
.filter-sort select{background:var(--card);border:1px solid var(--line2);color:var(--white);padding:10px 16px;font-size:0.7rem;font-family:'Montserrat',sans-serif;outline:none;appearance:none;}
.cars-grid{padding:0 60px;display:grid;grid-template-columns:repeat(3,1fr);gap:2px;}
.car-card{background:var(--card);position:relative;overflow:hidden;transition:transform 0.4s;border:1px solid var(--line2);}
.car-card:hover{transform:translateY(-6px);z-index:2;}
.car-card:hover .car-card-overlay{opacity:1;}
.car-card:hover .car-card-img img{transform:scale(1.06);}
.car-card:hover .car-card-cta{opacity:1;transform:translateY(0);}
.car-badge{position:absolute;top:20px;left:20px;z-index:3;font-size:0.55rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;padding:5px 12px;}
.badge-new{background:var(--gold);color:var(--black);}
.badge-hot{background:var(--red);color:white;}
.badge-exclu{background:var(--dark);border:1px solid var(--gold);color:var(--gold);}
.car-fav{position:absolute;top:20px;right:20px;z-index:3;background:rgba(5,5,7,0.6);border:1px solid var(--line2);color:var(--muted);width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:1rem;transition:all 0.3s;backdrop-filter:blur(4px);}
.car-fav:hover,.car-fav.active{border-color:var(--gold);color:var(--gold);}
.car-card-img{height:240px;background:var(--dark2);overflow:hidden;position:relative;}
.car-card-img::after{content:'';position:absolute;bottom:0;left:0;right:0;height:40%;background:linear-gradient(transparent,var(--card));z-index:1;}
.car-card-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.5s;}
.car-card-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(201,168,76,0.05) 0%,transparent 60%);opacity:0;transition:opacity 0.4s;z-index:2;}
.car-card-body{padding:24px;}
.car-card-brand{font-size:0.58rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:6px;}
.car-card-name{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;line-height:1.2;margin-bottom:4px;}
.car-card-version{font-size:0.65rem;color:var(--muted);margin-bottom:18px;letter-spacing:1px;}
.car-card-specs{display:flex;gap:20px;border-top:1px solid var(--line2);padding-top:16px;margin-bottom:20px;}
.spec-val{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:700;}
.spec-unit{font-size:0.58rem;color:var(--gold);font-weight:700;}
.spec-label{font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:2px;}
.car-card-footer{display:flex;align-items:flex-end;justify-content:space-between;}
.price-from{font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);}
.price-val{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;color:var(--gold2);line-height:1.1;}
.price-currency{font-size:1rem;color:var(--muted);}
.car-card-cta{background:var(--gold);color:var(--black);border:none;padding:10px 18px;font-size:0.58rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;opacity:0;transform:translateY(8px);transition:all 0.3s;}
.car-card.featured{grid-column:span 2;}
.car-card.featured .car-card-img{height:320px;}
.page{display:none;position:fixed;inset:0;z-index:2000;background:var(--black);overflow-y:auto;}
.page.open{display:block;}
.page-close{position:fixed;top:24px;right:24px;z-index:2100;background:rgba(5,5,7,0.8);border:1px solid var(--line);color:var(--white);width:48px;height:48px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;transition:all 0.3s;backdrop-filter:blur(10px);}
.page-close:hover{border-color:var(--gold);color:var(--gold);}
.detail-hero{height:72vh;position:relative;overflow:hidden;}
.detail-hero img{width:100%;height:100%;object-fit:cover;}
.detail-hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,var(--black) 0%,rgba(5,5,7,0.2) 60%,transparent 100%);}
.detail-hero-info{position:absolute;bottom:60px;left:60px;right:60px;z-index:2;}
.detail-brand{font-size:0.62rem;font-weight:700;letter-spacing:5px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;}
.detail-title{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,7vw,6rem);font-weight:300;line-height:1;margin-bottom:8px;}
.detail-title strong{font-weight:700;}
.detail-subtitle{font-size:0.75rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
.detail-body{padding:80px 60px;display:grid;grid-template-columns:1fr 380px;gap:80px;max-width:1400px;margin:0 auto;}
.detail-specs-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-bottom:50px;}
.dspec{background:var(--card);padding:24px 20px;text-align:center;border:1px solid var(--line2);}
.dspec-val{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:700;color:var(--gold2);line-height:1;}
.dspec-unit{font-size:0.7rem;color:var(--gold);}
.dspec-label{font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:6px;}
.detail-desc{font-size:0.85rem;line-height:2;color:var(--muted);font-weight:300;margin-bottom:40px;}
.detail-features{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:50px;}
.detail-feature{display:flex;align-items:center;gap:12px;font-size:0.72rem;color:var(--muted);}
.detail-feature::before{content:'';width:6px;height:6px;background:var(--gold);border-radius:50%;flex-shrink:0;}
.detail-gallery{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:30px;}
.detail-gallery-img{overflow:hidden;}
.detail-gallery-img img{width:100%;height:200px;object-fit:cover;transition:transform 0.4s;}
.detail-gallery-img:hover img{transform:scale(1.05);}
.detail-price-box{background:var(--card);border:1px solid var(--line);padding:36px;margin-bottom:2px;}
.detail-price-label{font-size:0.58rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
.detail-price{font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:700;color:var(--gold2);line-height:1;margin-bottom:24px;}
.detail-stock{display:flex;align-items:center;gap:8px;font-size:0.62rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:28px;}
.detail-stock-dot{width:8px;height:8px;background:#25d366;border-radius:50%;box-shadow:0 0 8px #25d366;}
.detail-sidebar-actions{display:flex;flex-direction:column;gap:10px;}
.detail-sidebar-actions .btn-primary{clip-path:none;text-align:center;}
.config-btn-sm{background:var(--card2);color:var(--gold);border:1px solid var(--gold);padding:14px;font-size:0.62rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;text-align:center;transition:all 0.3s;}
.config-btn-sm:hover{background:var(--gold);color:var(--black);}
.detail-tabs{display:flex;gap:0;margin-bottom:40px;border-bottom:1px solid var(--line2);}
.detail-tab{padding:14px 24px;font-size:0.62rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all 0.3s;}
.detail-tab.active{color:var(--gold);border-bottom-color:var(--gold);}
.detail-tab-content{display:none;}
.detail-tab-content.active{display:block;}
.lightbox{position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,0.96);display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;transition:all 0.4s;}
.lightbox.open{opacity:1;visibility:visible;}
.lightbox img{max-width:90vw;max-height:85vh;object-fit:contain;}
.lightbox-close{position:absolute;top:24px;right:24px;background:transparent;border:1px solid var(--line);color:var(--white);width:48px;height:48px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;transition:all 0.3s;}
.lightbox-close:hover{border-color:var(--gold);color:var(--gold);}
.lightbox-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(201,168,76,0.1);border:1px solid var(--line);color:var(--gold);width:52px;height:52px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;transition:all 0.3s;}
.lightbox-nav:hover{background:var(--gold);color:var(--black);}
.lightbox-prev{left:24px;}
.lightbox-next{right:24px;}
.lightbox-caption{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);font-size:0.62rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
.config-page{display:none;position:fixed;inset:0;z-index:3000;background:var(--black);overflow:hidden;}
.config-page.open{display:block;}
.config-layout{display:grid;grid-template-columns:1fr 420px;height:100vh;}
.config-preview{position:relative;background:linear-gradient(135deg,var(--dark2) 0%,var(--card) 100%);display:flex;align-items:center;justify-content:center;overflow:hidden;}
.config-preview-car{width:85%;position:relative;z-index:2;}
.config-preview-car img{width:100%;object-fit:contain;filter:drop-shadow(0 40px 80px rgba(201,168,76,0.15));transition:filter 0.5s;}
.config-color-overlay{position:absolute;inset:0;transition:background 0.5s;mix-blend-mode:color;pointer-events:none;opacity:0.18;z-index:1;}
.config-preview-info{position:absolute;bottom:40px;left:40px;z-index:3;}
.config-preview-brand{font-size:0.6rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:6px;}
.config-preview-title{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;}
.config-preview-title strong{font-weight:700;}
.config-panel{background:var(--dark);overflow-y:auto;display:flex;flex-direction:column;}
.config-panel-header{padding:28px 36px;border-bottom:1px solid var(--line2);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--dark);z-index:10;}
.config-panel-title{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:600;}
.config-close{background:transparent;border:1px solid var(--line2);color:var(--muted);width:40px;height:40px;display:flex;align-items:center;justify-content:center;transition:all 0.3s;}
.config-close:hover{border-color:var(--gold);color:var(--gold);}
.config-section{padding:24px 36px;border-bottom:1px solid var(--line2);}
.config-section-title{font-size:0.6rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:18px;}
.config-colors{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px;}
.config-color{width:42px;height:42px;border-radius:50%;border:3px solid transparent;transition:all 0.3s;position:relative;}
.config-color.active,.config-color:hover{border-color:var(--gold);transform:scale(1.1);}
.config-color-name{position:absolute;bottom:-20px;left:50%;transform:translateX(-50%);font-size:0.48rem;letter-spacing:1px;white-space:nowrap;color:var(--muted);opacity:0;transition:opacity 0.2s;}
.config-color:hover .config-color-name{opacity:1;}
.config-wheels{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.config-wheel{background:var(--card);border:1px solid var(--line2);padding:14px 10px;text-align:center;transition:all 0.3s;}
.config-wheel.active,.config-wheel:hover{border-color:var(--gold);background:var(--card2);}
.config-wheel-icon{font-size:1.8rem;margin-bottom:6px;}
.config-wheel-name{font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);}
.config-wheel.active .config-wheel-name{color:var(--gold);}
.config-interior{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
.config-int-item{background:var(--card);border:1px solid var(--line2);padding:12px;transition:all 0.3s;display:flex;align-items:center;gap:10px;}
.config-int-item.active,.config-int-item:hover{border-color:var(--gold);}
.config-int-swatch{width:30px;height:30px;border-radius:4px;flex-shrink:0;}
.config-int-label{font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);}
.config-int-item.active .config-int-label{color:var(--gold);}
.config-options{display:flex;flex-direction:column;gap:8px;}
.config-option{background:var(--card);border:1px solid var(--line2);padding:12px 14px;transition:all 0.3s;display:flex;align-items:center;justify-content:space-between;}
.config-option.active{border-color:var(--gold);}
.config-option-label{font-size:0.66rem;font-weight:600;color:var(--white);}
.config-option-price{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--gold);}
.config-option-check{width:20px;height:20px;border:1px solid var(--line2);display:flex;align-items:center;justify-content:center;font-size:0.7rem;transition:all 0.3s;flex-shrink:0;}
.config-option.active .config-option-check{background:var(--gold);border-color:var(--gold);color:var(--black);}
.config-footer{padding:24px 36px;background:var(--dark);border-top:1px solid var(--line2);position:sticky;bottom:0;}
.config-total-label{font-size:0.58rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:4px;}
.config-total-price{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:700;color:var(--gold2);margin-bottom:16px;}
.config-footer-actions{display:flex;gap:10px;}
.config-footer-actions .btn-primary{flex:1;clip-path:none;text-align:center;}
.spotlight{padding:120px 60px;background:var(--dark2);position:relative;overflow:hidden;}
.spotlight-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.spotlight-car-visual{border:1px solid var(--line);overflow:hidden;position:relative;height:400px;}
.spotlight-car-visual img{width:100%;height:100%;object-fit:cover;transition:transform 0.6s;}
.spotlight-car-visual:hover img{transform:scale(1.04);}
.spotlight-car-badge{position:absolute;top:0;right:40px;background:var(--gold);color:var(--black);padding:8px 20px;font-size:0.6rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;z-index:2;}
.spotlight-car-num{position:absolute;bottom:-30px;left:-30px;font-family:'Cormorant Garamond',serif;font-size:10rem;font-weight:700;color:rgba(201,168,76,0.06);pointer-events:none;user-select:none;z-index:3;}
.spotlight-tag{display:inline-block;border:1px solid var(--gold);color:var(--gold);padding:6px 16px;font-size:0.58rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;margin-bottom:28px;}
.spotlight-title{font-family:'Cormorant Garamond',serif;font-size:3.4rem;font-weight:300;line-height:1.05;margin-bottom:8px;}
